# Application
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://lguis_user:lguis_password@localhost:5432/lguis_db

# JWT
JWT_SECRET=change-this-to-a-random-secret-key-in-production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change-this-to-a-different-secret-key-in-production
JWT_REFRESH_EXPIRES_IN=24h

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# LGU Settings
LGU_NAME=Municipality of Lagonoy
LGU_PROVINCE=Camarines Sur
LGU_ADDRESS=Lagonoy, Camarines Sur
